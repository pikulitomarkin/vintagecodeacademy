@inherits LayoutComponentBase
@using MudBlazor

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Dark">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="ToggleDrawer" />
        <MudText Typo="Typo.h6" Class="ml-3">VintageCodeAcademy</MudText>
        <MudSpacer />
        <MudIconButton Icon="@Icons.Material.Filled.AccountCircle" Color="Color.Inherit" Href="/profile" />
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2">
        <MudNavMenu>
            <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home">Início</MudNavLink>
            <MudNavLink Href="/trails" Icon="@Icons.Material.Filled.School">Trilhas</MudNavLink>
            <MudNavLink Href="/ranking" Icon="@Icons.Material.Filled.Leaderboard">Ranking</MudNavLink>
            <MudNavLink Href="/labs" Icon="@Icons.Material.Filled.Science">VCA Labs</MudNavLink>
            <MudNavLink Href="/profile" Icon="@Icons.Material.Filled.Person">Meu Perfil</MudNavLink>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="my-6">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;
}
