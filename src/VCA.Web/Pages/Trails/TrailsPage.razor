@page "/trilhas"
@using VCA.Web.Services
@inject CourseHttpService CourseService
@inject NavigationManager Nav

<PageTitle>Trilhas — VintageCodeAcademy</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-6">

    <!-- Header -->
    <MudText Typo="Typo.h4" Class="mb-1" Style="color:var(--mud-palette-primary)">
        Trilhas de Aprendizado
    </MudText>
    <MudText Typo="Typo.body1" Class="mb-6" Style="opacity:.7">
        Escolha seu caminho e evolua de Rookie a Vintage Dev
    </MudText>

    <!-- Filtros de nível -->
    <MudChipSet @bind-SelectedChip="_selectedChip" Class="mb-6" Mandatory>
        <MudChip Value="@("Todos")" Color="Color.Primary" Variant="Variant.Filled" Default>Todos</MudChip>
        <MudChip Value="@("Beginner")" Color="Color.Default" Variant="Variant.Outlined">🌱 Iniciante</MudChip>
        <MudChip Value="@("Intermediate")" Color="Color.Default" Variant="Variant.Outlined">🔥 Intermediário</MudChip>
        <MudChip Value="@("Advanced")" Color="Color.Default" Variant="Variant.Outlined">⚡ Avançado</MudChip>
    </MudChipSet>

    <!-- Grid de cards -->
    @if (_loading)
    {
        <!-- Skeleton -->
        <MudGrid>
            @for (var i = 0; i < 6; i++)
            {
                <MudItem xs="12" sm="6" lg="4">
                    <MudCard Class="pa-4" Style="background:#1A1A1A;border-radius:18px;height:280px;">
                        <MudSkeleton SkeletonType="SkeletonType.Circle" Width="56px" Height="56px" Class="mb-3" />
                        <MudSkeleton Width="70%" Height="24px" Class="mb-2" />
                        <MudSkeleton Width="50%" Height="16px" Class="mb-4" />
                        <MudSkeleton Width="100%" Height="8px" Class="mb-2" />
                        <MudSkeleton Width="40%" Height="36px" />
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
    else if (_filteredTrails.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Style="background:#1A1A1A;border-radius:12px;">
            Nenhuma trilha encontrada para este filtro.
        </MudAlert>
    }
    else
    {
        <MudGrid>
            @foreach (var trail in _filteredTrails)
            {
                var progress = _progressMap.GetValueOrDefault(trail.Id);
                var started = progress is not null && progress.CompletedLessons > 0;
                var pct = (trail.TotalLessons > 0 && started)
                    ? (int)Math.Round(progress!.CompletedLessons * 100.0 / trail.TotalLessons)
                    : 0;

                <MudItem xs="12" sm="6" lg="4">
                    <MudCard Class="trail-card pa-4" Style="background:#1A1A1A;border-radius:18px;border:1px solid #262626;transition:transform .2s,box-shadow .2s;height:100%;">
                        <MudCardContent>
                            <div class="d-flex align-center mb-3">
                                <MudAvatar Style="background:linear-gradient(135deg,#00C9C9,#007A7A);font-size:1.5rem;width:52px;height:52px;">
                                    @GetTrailEmoji(trail.Stack)
                                </MudAvatar>
                                <div class="ml-3">
                                    <MudChip Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined"
                                             Style="font-size:.7rem;height:22px;">
                                        @LevelLabel(trail.Level)
                                    </MudChip>
                                </div>
                            </div>

                            <MudText Typo="Typo.h6" Style="font-weight:700;line-height:1.3;">@trail.Title</MudText>
                            <MudText Typo="Typo.body2" Style="opacity:.6;margin-top:2px;margin-bottom:12px;">
                                @trail.Stack
                            </MudText>

                            <MudText Typo="Typo.caption" Style="opacity:.5;">
                                @trail.TotalLessons aulas
                            </MudText>

                            @if (started)
                            {
                                <div class="mt-3">
                                    <div class="d-flex justify-space-between mb-1">
                                        <MudText Typo="Typo.caption" Style="opacity:.6;">Progresso</MudText>
                                        <MudText Typo="Typo.caption" Style="color:var(--mud-palette-primary);">@pct%</MudText>
                                    </div>
                                    <MudProgressLinear Value="@pct" Color="Color.Primary" Rounded Size="Size.Small" />
                                </div>
                            }
                        </MudCardContent>

                        <MudCardActions Class="pt-0 px-4 pb-4">
                            <MudButton FullWidth
                                       Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       Style="border-radius:12px;font-weight:600;"
                                       OnClick="@(() => Nav.NavigateTo($"/trilhas/{trail.Id}"))">
                                @(started ? "Continuar" : "Começar")
                            </MudButton>
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
</MudContainer>

<style>
    .trail-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 32px rgba(0,201,201,0.18);
    }
</style>
